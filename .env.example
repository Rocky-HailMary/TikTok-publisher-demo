PORT=3000
APP_BASE_URL=https://api.hypercreative.games

TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_REDIRECT_URI=https://api.hypercreative.games/auth/tiktok/callback
TIKTOK_SCOPES=user.info.basic,video.publish

# Optional overrides
TIKTOK_AUTH_BASE=https://www.tiktok.com
TIKTOK_API_BASE=https://open.tiktokapis.com
DEMO_VIDEO_URL=

# Local file upload mode (no cloud storage)
MAX_UPLOAD_MB=200
LOCAL_UPLOAD_TTL_MIN=120

# Mac mini clip bridge mode (Option 1)
MAC_BRIDGE_BASE_URL=https://clips.hypercreative.games
MAC_BRIDGE_TOKEN=replace_with_bridge_token
# Optional: only needed if bridge requires token query for /clips/:name
MAC_BRIDGE_FILE_TOKEN=

# Allow Wix site origin(s) for cross-origin calls (comma-separated)
ALLOWED_ORIGINS=https://www.hypercreative.games,https://hypercreative.games

# Optional: share cookie across subdomains
SESSION_COOKIE_DOMAIN=.hypercreative.games

# Cookie policy for OAuth/session; use none for cross-site redirect flows
SESSION_SAMESITE=none

# Change in production
SESSION_SECRET=replace_with_a_long_random_secret
